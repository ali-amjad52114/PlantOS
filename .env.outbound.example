# Outbound share (Slack via Pipedream Connect) — isolated; off by default
# Copy into .env.local and Trigger.dev dashboard. Never commit real secrets.

# Master kill switch (also requires Pipedream credentials below)
PLANTOS_OUTBOUND_ENABLED=false

# Pipedream Connect (server-only — never NEXT_PUBLIC_ for secrets)
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_PROJECT_ENVIRONMENT=development
PIPEDREAM_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Demo operator identity (server-derived; never accept from the browser)
PLANTOS_PD_EXTERNAL_USER_ID=plantos:demo:operator

# Fixed Slack destination for v1
PLANTOS_SLACK_CHANNEL_ID=
PLANTOS_SLACK_CHANNEL_LABEL=test

# Optional action id overrides
# PLANTOS_SLACK_SEND_ACTION_ID=slack-send-message-to-channel
# PLANTOS_SLACK_DELETE_ACTION_ID=slack-delete-message
